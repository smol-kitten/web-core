ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

# Install packages
RUN apt-get update && apt-get install -y software-properties-common        

RUN apt-get upgrade -yy

# Install build dependencies for PHP compilation
RUN apt-get install -y \
    build-essential \
    autoconf \
    bison \
    re2c \
    pkg-config \
    libxml2-dev \
    libsqlite3-dev \
    libssl-dev \
    libcurl4-openssl-dev \
    libonig-dev \
    libreadline-dev \
    libbz2-dev \
    libzip-dev \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    libwebp-dev \
    libxpm-dev \
    libgd-dev \
    zlib1g-dev \
    libsodium-dev \
    libargon2-dev \
    libicu-dev \
    wget \
    ca-certificates

# Download and extract PHP 8.4.14
WORKDIR /usr/src
RUN wget -q https://www.php.net/distributions/php-8.4.1.tar.gz && \
    tar -xzf php-8.4.1.tar.gz && \
    rm php-8.4.1.tar.gz

# Build PHP 8.4 with all common extensions
WORKDIR /usr/src/php-8.4.1
RUN ./configure \
    --prefix=/usr/local/php8.4 \
    --with-config-file-path=/usr/local/php8.4/etc \
    --with-config-file-scan-dir=/usr/local/php8.4/etc/conf.d \
    --enable-fpm \
    --with-fpm-user=www-data \
    --with-fpm-group=www-data \
    --enable-cli \
    --enable-cgi \
    --enable-bcmath \
    --enable-calendar \
    --enable-exif \
    --enable-ftp \
    --enable-gd \
    --with-external-gd \
    --enable-intl \
    --enable-mbstring \
    --enable-opcache \
    --enable-pcntl \
    --enable-shmop \
    --enable-soap \
    --enable-sockets \
    --enable-sysvmsg \
    --enable-sysvsem \
    --enable-sysvshm \
    --with-bz2 \
    --with-curl \
    --with-openssl \
    --with-readline \
    --with-zip \
    --with-zlib \
    --with-pdo-mysql \
    --with-pdo-sqlite \
    --with-mysqli \
    --with-sodium \
    --with-password-argon2

RUN make -j$(nproc)

# Install PHP
RUN make install

# Install PEAR/PECL
RUN cd /usr/src/php-8.4.1 && \
    wget -q https://pear.php.net/go-pear.phar && \
    /usr/local/php8.4/bin/php go-pear.phar && \
    rm go-pear.phar

# Create symlinks for standard locations
RUN ln -sf /usr/local/php8.4/bin/php /usr/local/bin/php && \
    ln -sf /usr/local/php8.4/bin/php-cgi /usr/local/bin/php-cgi && \
    ln -sf /usr/local/php8.4/bin/php-config /usr/local/bin/php-config && \
    ln -sf /usr/local/php8.4/bin/phpize /usr/local/bin/phpize && \
    ln -sf /usr/local/php8.4/bin/pecl /usr/local/bin/pecl && \
    ln -sf /usr/local/php8.4/bin/pear /usr/local/bin/pear && \
    ln -sf /usr/local/php8.4/sbin/php-fpm /usr/local/bin/php-fpm

# Create PHP-FPM config directories
RUN mkdir -p /usr/local/php8.4/etc/conf.d && \
    mkdir -p /usr/local/php8.4/etc/php-fpm.d && \
    mkdir -p /var/log/php-fpm && \
    mkdir -p /var/run/php

# Copy default configs
RUN cp /usr/src/php-8.4.1/php.ini-production /usr/local/php8.4/etc/php.ini && \
    cp /usr/src/php-8.4.1/sapi/fpm/php-fpm.conf /usr/local/php8.4/etc/php-fpm.conf && \
    cp /usr/src/php-8.4.1/sapi/fpm/www.conf /usr/local/php8.4/etc/php-fpm.d/www.conf

# Configure PHP-FPM to run as www-data
RUN sed -i 's/;pid = run\/php-fpm.pid/pid = \/var\/run\/php\/php8.4-fpm.pid/' /usr/local/php8.4/etc/php-fpm.conf && \
    sed -i 's/;error_log = log\/php-fpm.log/error_log = \/var\/log\/php-fpm\/error.log/' /usr/local/php8.4/etc/php-fpm.conf && \
    sed -i 's/listen = 127.0.0.1:9000/listen = \/var\/run\/php\/php8.4-fpm.sock/' /usr/local/php8.4/etc/php-fpm.d/www.conf && \
    sed -i 's/;listen.owner = www-data/listen.owner = www-data/' /usr/local/php8.4/etc/php-fpm.d/www.conf && \
    sed -i 's/;listen.group = www-data/listen.group = www-data/' /usr/local/php8.4/etc/php-fpm.d/www.conf && \
    sed -i 's/;listen.mode = 0660/listen.mode = 0660/' /usr/local/php8.4/etc/php-fpm.d/www.conf

# Remove build dependencies and unnecessary packages
# NOTE: Keep runtime libraries needed by PHP extensions
# NOTE: Keep imagemagick/libmagick* as they are needed for imagick variants
# NOTE: Keep gnupg/gpgv as apt depends on them
# Use --ignore-missing to avoid failures on packages that don't exist
RUN apt-get remove --ignore-missing -y \
    build-essential \
    autoconf \
    bison \
    re2c \
    pkg-config \
    gcc \
    gcc-13 \
    gcc-14 \
    g++ \
    g++-13 \
    g++-14 \
    cpp \
    cpp-13 \
    cpp-14 \
    binutils \
    binutils-common \
    binutils-x86-64-linux-gnu \
    make \
    automake \
    autotools-dev \
    libtool \
    libltdl-dev \
    manpages-dev \
    libxml2-dev \
    libsqlite3-dev \
    libssl-dev \
    libcurl4-openssl-dev \
    libonig-dev \
    libreadline-dev \
    libbz2-dev \
    libzip-dev \
    libpng-dev \
    libjpeg-dev \
    libjpeg8-dev \
    libjpeg-turbo8-dev \
    libfreetype-dev \
    libwebp-dev \
    libsharpyuv-dev \
    libxpm-dev \
    libgd-dev \
    zlib1g-dev \
    libsodium-dev \
    libargon2-dev \
    libicu-dev \
    libc-dev-bin \
    libc6-dev \
    linux-libc-dev \
    libcrypt-dev \
    libexpat1-dev \
    libfontconfig-dev \
    libbrotli-dev \
    libdeflate-dev \
    libjbig-dev \
    liblerc-dev \
    libtiff-dev \
    libzstd-dev \
    liblzma-dev \
    libncurses-dev \
    uuid-dev \
    xorg-sgml-doctools \
    xtrans-dev \
    libx11-dev \
    libxau-dev \
    libxcb1-dev \
    libxdmcp-dev \
    x11proto-dev \
    fonts-dejavu-core \
    fonts-dejavu-mono \
    fontconfig-config \
    dbus \
    dbus-bin \
    dbus-daemon \
    dbus-session-bus-common \
    dbus-system-bus-common \
    dbus-user-session \
    polkitd \
    libpolkit-agent-1-0 \
    libpolkit-gobject-1-0 \
    packagekit \
    packagekit-tools \
    libpackagekit-glib2-18 \
    gir1.2-packagekitglib-1.0 \
    gir1.2-girepository-2.0 \
    gir1.2-glib-2.0 \
    libgirepository-1.0-1 \
    python3-gi \
    dmsetup \
    libdevmapper1.02.1 \
    libcryptsetup12 \
    bzip2-doc \
    sgml-base \
    xml-core \
    lto-disabled-list \
    patch \
    fakeroot \
    libfakeroot \
    dpkg-dev \
    libdpkg-perl \
    perl \
    perl-modules-5.38 \
    libperl5.38t64 \
    libalgorithm-diff-perl \
    libalgorithm-diff-xs-perl \
    libalgorithm-merge-perl \
    libfile-fcntllock-perl \
    liblocale-gettext-perl \
    python3-blinker \
    python3-cffi-backend \
    python3-cryptography \
    python3-dbus \
    python3-distro \
    python3-distro-info \
    python3-httplib2 \
    python3-jwt \
    python3-launchpadlib \
    python3-lazr.restfulclient \
    python3-lazr.uri \
    python3-oauthlib \
    python3-pkg-resources \
    python3-pyparsing \
    python3-software-properties \
    python3-wadllib \
    networkd-dispatcher \
    software-properties-common \
    shared-mime-info \
    appstream \
    libappstream5 \
    libxmlb2 \
    iso-codes \
    publicsuffix \
    unattended-upgrades \
    libstemmer0d \
    libduktape207 \
    icu-devtools && \
    apt-get autoremove -y && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        libreadline8t64 \
        libsqlite3-0 \
        libxml2 \
        libcurl4t64 \
        libonig5 \
        libbz2-1.0 \
        libzip4t64 \
        libpng16-16t64 \
        libjpeg8 \
        libfreetype6 \
        libwebp7 \
        libgd3 \
        libsodium23 \
        libargon2-1 \
        libicu74 \
        libssl3t64 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /usr/src/php-8.4.1  

# Slim down the image size by stripping binaries
RUN strip --strip-all /usr/local/php8.4/bin/* /usr/local/php8.4/sbin/* /usr/local/php8.4/lib/php/extensions/no-debug-non-zts-20210902/*.so 2>/dev/null || true

# Slim down the image size by removing unneeded files
RUN find /usr/local/php8.4/ -type f \( -name '*.a' -o -name '*.la' \) -delete

# Remove source code directories
RUN rm -rf /usr/src

# Slim down the image size by removing documentation files
RUN find /usr/local/php8.4/ -type f \( -name 'README*' -o -name 'CHANGELOG*' -o -name 'UPGRADING*' -o -name 'NEWS*' \) -delete

# Remove man pages to save space
RUN rm -rf /usr/local/php8.4/share/man /usr/share/man /usr/local/share/man

# Additional cleanup - remove package cache and temporary files
RUN rm -rf /var/cache/apt/* \
    /var/lib/apt/lists/* \
    /tmp/* \
    /var/tmp/* \
    /var/cache/debconf/* \
    /var/log/* \
    /usr/share/doc/* \
    /usr/share/info/* \
    /usr/share/locale/* \
    /usr/share/pixmaps/* \
    /usr/share/icons/* \
    /usr/share/applications/* \
    2>/dev/null || true

# Recreate necessary runtime directories after cleanup
RUN mkdir -p /var/log/php-fpm /var/run/php

WORKDIR /