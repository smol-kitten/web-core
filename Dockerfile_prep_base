# PHP Builder Image
# Compiles PHP from source with all extensions pre-built.
# Pushed to the registry and used as the builder stage in Dockerfile_specific.
#
# Build args:
#   BASE_IMAGE   - Ubuntu base image (default ubuntu:24.04)
#   PHP_VERSION  - Full PHP version string e.g. 8.4.6

ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

# Use bash with pipefail for safer RUN commands
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ARG PHP_VERSION=8.4.6

# Security: upgrade pre-installed OS packages before adding our own
RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        build-essential \
        autoconf \
        bison \
        re2c \
        pkg-config \
        libxml2-dev \
        libsqlite3-dev \
        libssl-dev \
        libcurl4-openssl-dev \
        libonig-dev \
        libreadline-dev \
        libbz2-dev \
        libzip-dev \
        libpng-dev \
        libjpeg-dev \
        libfreetype6-dev \
        libwebp-dev \
        libxpm-dev \
        libgd-dev \
        zlib1g-dev \
        libsodium-dev \
        libargon2-dev \
        libicu-dev \
        wget \
        ca-certificates \
        libmagickwand-dev \
        imagemagick \
        libssh2-1-dev \
        libmemcached-dev && \
    rm -rf /var/lib/apt/lists/*

# Download and extract PHP source
WORKDIR /usr/src
RUN wget -q "https://www.php.net/distributions/php-${PHP_VERSION}.tar.gz" && \
    tar -xzf "php-${PHP_VERSION}.tar.gz" && \
    rm "php-${PHP_VERSION}.tar.gz"

WORKDIR /usr/src/php-${PHP_VERSION}
RUN ./configure \
        --prefix=/usr/local/php8.4 \
        --with-config-file-path=/usr/local/php8.4/etc \
        --with-config-file-scan-dir=/usr/local/php8.4/etc/conf.d \
        --enable-fpm \
        --with-fpm-user=www-data \
        --with-fpm-group=www-data \
        --enable-cli \
        --enable-cgi \
        --enable-bcmath \
        --enable-calendar \
        --enable-exif \
        --enable-ftp \
        --enable-gd \
        --with-external-gd \
        --enable-intl \
        --enable-mbstring \
        --enable-opcache \
        --enable-pcntl \
        --enable-shmop \
        --enable-soap \
        --enable-sockets \
        --enable-sysvmsg \
        --enable-sysvsem \
        --enable-sysvshm \
        --with-bz2 \
        --with-curl \
        --with-openssl \
        --with-readline \
        --with-zip \
        --with-zlib \
        --with-pdo-mysql \
        --with-pdo-sqlite \
        --with-mysqli \
        --with-sodium \
        --with-password-argon2 && \
    make -j$(nproc) && \
    make install

# PEAR/PECL bootstrap
RUN wget -q https://pear.php.net/go-pear.phar && \
    /usr/local/php8.4/bin/php go-pear.phar && \
    rm -f go-pear.phar

# Standard symlinks
RUN ln -sf /usr/local/php8.4/bin/php        /usr/local/bin/php && \
    ln -sf /usr/local/php8.4/bin/php-cgi    /usr/local/bin/php-cgi && \
    ln -sf /usr/local/php8.4/bin/php-config /usr/local/bin/php-config && \
    ln -sf /usr/local/php8.4/bin/phpize     /usr/local/bin/phpize && \
    ln -sf /usr/local/php8.4/bin/pecl       /usr/local/bin/pecl && \
    ln -sf /usr/local/php8.4/bin/pear       /usr/local/bin/pear && \
    ln -sf /usr/local/php8.4/sbin/php-fpm   /usr/local/bin/php-fpm

# Config directories and runtime paths
RUN mkdir -p /usr/local/php8.4/etc/conf.d \
             /usr/local/php8.4/etc/php-fpm.d \
             /var/log/php-fpm \
             /var/run/php

# Install default configs and tune PHP-FPM for socket mode
RUN cp /usr/src/php-${PHP_VERSION}/php.ini-production \
       /usr/local/php8.4/etc/php.ini && \
    cp /usr/src/php-${PHP_VERSION}/sapi/fpm/php-fpm.conf \
       /usr/local/php8.4/etc/php-fpm.conf && \
    cp /usr/src/php-${PHP_VERSION}/sapi/fpm/www.conf \
       /usr/local/php8.4/etc/php-fpm.d/www.conf && \
    sed -i 's/;pid = run\/php-fpm.pid/pid = \/var\/run\/php\/php8.4-fpm.pid/'         /usr/local/php8.4/etc/php-fpm.conf && \
    sed -i 's/;error_log = log\/php-fpm.log/error_log = \/var\/log\/php-fpm\/error.log/' /usr/local/php8.4/etc/php-fpm.conf && \
    sed -i 's/listen = 127.0.0.1:9000/listen = \/var\/run\/php\/php8.4-fpm.sock/'     /usr/local/php8.4/etc/php-fpm.d/www.conf && \
    sed -i 's/;listen.owner = www-data/listen.owner = www-data/'                       /usr/local/php8.4/etc/php-fpm.d/www.conf && \
    sed -i 's/;listen.group = www-data/listen.group = www-data/'                       /usr/local/php8.4/etc/php-fpm.d/www.conf && \
    sed -i 's/;listen.mode = 0660/listen.mode = 0660/'                                /usr/local/php8.4/etc/php-fpm.d/www.conf

# Build PECL extensions (imagick, ssh2, redis, memcached)
RUN cd /tmp && \
    wget -q https://pecl.php.net/get/imagick && \
    mkdir imagick-src && tar -xzf imagick -C imagick-src --strip-components=1 && \
    cd imagick-src && \
    /usr/local/bin/phpize && \
    ./configure --with-php-config=/usr/local/bin/php-config && \
    make -j$(nproc) && make install && \
    echo "extension=imagick.so" > /usr/local/php8.4/etc/conf.d/20-imagick.ini && \
    cd / && rm -rf /tmp/imagick-src /tmp/imagick

RUN pecl install ssh2-1.4.1 && \
    echo "extension=ssh2.so" > /usr/local/php8.4/etc/conf.d/20-ssh2.ini

RUN pecl install redis && \
    echo "extension=redis.so" > /usr/local/php8.4/etc/conf.d/20-redis.ini

RUN pecl install memcached && \
    echo "extension=memcached.so" > /usr/local/php8.4/etc/conf.d/20-memcached.ini

# Strip binaries, remove static libs, test/doc dirs, and build artefacts
RUN strip --strip-all /usr/local/php8.4/bin/* /usr/local/php8.4/sbin/* 2>/dev/null || true && \
    find /usr/local/php8.4/lib/php/extensions/ -name '*.so' \
        -exec strip --strip-all {} \; 2>/dev/null || true && \
    find /usr/local/php8.4/ -type f \( -name '*.a' -o -name '*.la' \) -delete && \
    rm -rf /usr/src/php-${PHP_VERSION} && \
    rm -rf /usr/local/php8.4/lib/php/test && \
    rm -rf /usr/local/php8.4/lib/php/doc && \
    rm -rf /var/cache/pear /tmp/pear /tmp/pear_* && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

WORKDIR /
