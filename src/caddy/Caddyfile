{
	admin off
	# auto_https is managed by the entrypoint:
	# removed (enabled) when FORCE_HTTPS=true, kept (disabled) otherwise
	auto_https off
}

:{$WEB_PORT:80} {
	root * /var/www/html

	# PHP via PHP-FPM socket
	php_fastcgi unix//var/run/php/php8.4-fpm.sock {
		root /var/www/html
	}

	file_server

	encode zstd gzip

	# Security headers (block is removed by entrypoint when SECURITY_HEADERS=false)
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
		-Server
	}

	# Block sensitive paths
	@sensitive {
		path_regexp \.(git|env|conf|bak|sql|sh|ini|log|inc|old|orig|swp|dmp)$
		path_regexp /\..*
	}
	respond @sensitive 403

	log {
		output stdout
		format console
	}
}
